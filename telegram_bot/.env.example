# ============================================================
# .env — Credenziali 90dayman Mental Coach
# COPIA questo file come .env e riempi i valori reali
# NON committare mai il file .env su GitHub
# ============================================================

# ── TELEGRAM ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=il_tuo_token_da_botfather

# Il tuo ID numerico Telegram (cercalo con @userinfobot)
YOUR_TELEGRAM_ID=123456789

# ── NEO4J ────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://dc3a7e56.databases.neo4j.io
NEO4J_USER=dc3a7e56
NEO4J_PASSWORD=la_tua_password_neo4j
NEO4J_DATABASE=dc3a7e56

# ── GEMINI AI ────────────────────────────────────────────────
GEMINI_API_KEY=la_tua_api_key_gemini

# ── WEB APP ──────────────────────────────────────────────────
# Aggiorna questo dopo il deploy su Google Apps Script
WEB_APP_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec

# ── FASTAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Chiave segreta per autenticare Google Apps Script → API
# Generala con: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET=cambia_questa_stringa_con_una_casuale_lunga
